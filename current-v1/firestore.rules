rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Check if user is admin
    function isAdmin() {
      return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    match /users/{userId} {
      // Users can read their own profile, admins can read all
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      
      // Users can create their own profile upon registration
      // Enforce default fields: role must be 'member' and status 'pending'
      allow create: if request.auth != null 
                    && request.auth.uid == userId
                    && request.resource.data.role == 'member'
                    && request.resource.data.status == 'pending';
                    
      // Only admins can update profiles (e.g. approve/reject, promote) or delete
      allow update, delete: if isAdmin();
    }

    match /events/{eventId} {
      // Anyone can see events
      allow read: if true;
      // Only admins can create/update/delete events
      allow write: if isAdmin();
    }

    match /hardware/{hwId} {
      // Anyone logged in can see hardware (or we can change to true if public)
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /allocations/{allocationId} {
      // Admins can read all, members can read their own
      allow read: if request.auth != null && (request.auth.uid == resource.data.userId || isAdmin());
      allow write: if isAdmin();
    }
  }
}
