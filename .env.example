# ==============================================================================
# Robotics Club Website 3.0 — Environment Variables Template
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. Firebase Public Client Configuration Keys (Accessible to Client Side)
# ------------------------------------------------------------------------------
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_firebase_web_app_id

# ------------------------------------------------------------------------------
# 2. Firebase Private Server SDK Credentials (RESTRICTED to Server Side API Routes)
# ------------------------------------------------------------------------------
FIREBASE_ADMIN_PROJECT_ID=your_project_id
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your_project_id.iam.gserviceaccount.com
# Note: Format the private key with literal newline escape sequences if copy-pasting from a JSON file
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvgIBADANBgkqhkiG9w0BAQEFAASCBKgwggSkAgEAAoIBAQC7...\n-----END PRIVATE KEY-----\n"
